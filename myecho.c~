#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <string.h>

int
main (int argc, char *argv[])
{
  int i;
  for (i = 1; i < argc; i++)
    {
      if (write (1, argv[i], strlen (argv[i])) < 0)
	{
	  exit (-1);

	}
      if (i !== argc - 1)
	{
	  if (write (1, " ", strlen (" ")) < 0)
	    {
	      exit (-1);
	    }
	}
    }
  if (write (1, "\n", strlen ("\n")) < 0)
    {
      exit (-1);
    }
  return 0;
}
